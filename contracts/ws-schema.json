{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VC WebSocket Envelope",
  "type": "object",
  "required": ["event", "data"],
  "properties": {
    "requestId": {
      "type": "string",
      "description": "Client-generated correlation id echoed by server in direct responses."
    },
    "event": {
      "type": "string",
      "enum": [
        "join",
        "createTransport",
        "connectTransport",
        "produce",
        "consume",
        "listProducers",
        "pauseProducer",
        "resumeProducer",
        "qualityReport",
        "leave",
        "ping",
        "joined",
        "transportCreated",
        "produced",
        "consumed",
        "participantUpdate",
        "qualityAlert",
        "reconnectHint",
        "error",
        "ack"
      ]
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
