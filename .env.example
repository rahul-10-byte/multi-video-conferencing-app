# Server
PORT=9000
VC_BASE_URL=http://localhost:9000
VC_JWT_SECRET=replace-with-strong-secret
VC_API_KEY=replace-with-admin-api-key

# Customer invite + dev OTP
VC_CUSTOMER_INVITE_BASE_URL=http://localhost:9000/vc/join
VC_TEST_OTP_CODE=123456

# Database (read-model + replay store)
DATABASE_URL=postgres://postgres:12345678@localhost:5432/vc_backend
DATABASE_SSL=false

# TURN / STUN
TURN_STUN_URL=stun:localhost:3478
TURN_URL=turn:localhost:3478?transport=udp
TURN_USERNAME=sfuuser
TURN_PASSWORD=sfupass123

# Mediasoup
MEDIASOUP_LISTEN_IP=127.0.0.1
MEDIASOUP_ANNOUNCED_ADDRESS=
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999

# Recording (per-participant FFmpeg -> S3 -> Lambda merge)
VC_RECORDING_ENABLED=true
VC_RECORDING_HOST_IP=127.0.0.1
VC_RECORDING_BASE_PORT=50040
VC_RECORDING_S3_BUCKET=atlas-vc-recordings
VC_RECORDING_PROCESSING_LAMBDA=atlas-vc-recording-processor
AWS_REGION=ap-south-2
